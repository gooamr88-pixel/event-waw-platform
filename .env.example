# ══════════════════════════════════
# EVENT WAW — Environment Variables
# ══════════════════════════════════

# ── Client-side (safe to expose, bundled by Vite) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_STRIPE_PK=pk_test_your-publishable-key

# ── Server-side ONLY (never prefix with VITE_) ──
# Set these via Supabase CLI, NOT in this file:
#
#   supabase secrets set HMAC_SECRET=$(openssl rand -hex 32)
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase secrets set BREVO_API_KEY=xkeysib-...
#   supabase secrets set BREVO_SENDER_EMAIL=your-verified@domain.com
#   supabase secrets set BREVO_SENDER_NAME="Event Waw"
#   supabase secrets set ALLOWED_ORIGIN=https://yourdomain.com
