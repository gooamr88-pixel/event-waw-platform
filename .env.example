# ══════════════════════════════════
# EVENT WAW — Environment Variables
# ══════════════════════════════════

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe
VITE_STRIPE_PK=pk_test_your-key

# QR HMAC Secret
VITE_HMAC_SECRET=change-me-to-random-secret

# Brevo (Email OTP)
# Get REST API key from: https://app.brevo.com/settings/keys/api
VITE_BREVO_API_KEY=xkeysib-your-api-key
VITE_BREVO_SENDER_EMAIL=your-verified-sender@domain.com
VITE_BREVO_SENDER_NAME=Event Waw
